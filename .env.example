SPOTIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
FRONTEND_URL=http://localhost:3000

# === Banco de dados ===
# DEV (default): SQLite local, arquivo gerado no startup.
DATABASE_URL=sqlite:///./kisco.db
#
# PROD (Supabase): connection string do "Session pooler" (porta 5432).
# Pega em: Supabase Dashboard > Project Settings > Database > Connection string > URI.
# Trocar o prefixo "postgresql://" por "postgresql+psycopg://" pra forçar o driver v3.
# sslmode=require é obrigatório no Supabase.
DATABASE_URL=postgresql+psycopg://postgres.<ref>:<SENHA>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

SESSION_SECRET=gere-uma-string-aleatoria-de-32-bytes

LASTFM_API_KEY=xxxxxxxxxxxxxxxxxxxx
LASTFM_SHARED_SECRET=xxxxxxxxxxxxxxxxxxxx
LASTFM_REDIRECT_URI=http://127.0.0.1:8000/auth/lastfm/callback
